<?xml version="1.0" encoding="utf-8"?>
<image schemaversion="7.5" name="Pumice">
	<description type="system">
		<author>zearp</author>
		<contact>https://github.com/zearp/pumice-centos</contact>
		<specification>CentOS Stream 10</specification>
	</description>
	<preferences>
		<version>10</version>
		<packagemanager>dnf</packagemanager>
		<locale>en_GB</locale>
		<keytable>us</keytable>
		<timezone>Europe/Amsterdam</timezone>
		<release-version>10</release-version>
	</preferences>
	<repository type="rpm-md" alias="crb" sourcetype="metalink">
		<source path="https://mirrors.centos.org/metalink?repo=centos-crb-$releasever-stream&amp;arch=$basearch">
			<signing key="file:///usr/share/distribution-gpg-keys/centos/RPM-GPG-KEY-CentOS-10"/>
		</source>
	</repository>
	<repository type="rpm-md" alias="appstream" sourcetype="metalink">
		<source path="https://mirrors.centos.org/metalink?repo=centos-appstream-$releasever-stream&amp;arch=$basearch">
			<signing key="file:///usr/share/distribution-gpg-keys/centos/RPM-GPG-KEY-CentOS-10"/>
		</source>
	</repository>
	<repository type="rpm-md" alias="baseos" sourcetype="metalink">
		<source path="https://mirrors.centos.org/metalink?repo=centos-baseos-$releasever-stream&amp;arch=$basearch">
			<signing key="file:///usr/share/distribution-gpg-keys/centos/RPM-GPG-KEY-CentOS-10"/>
		</source>
	</repository>
	<repository type="rpm-md" alias="epel" sourcetype="metalink">
		<source path="https://mirrors.fedoraproject.org/metalink?repo=epel-10&amp;arch=$basearch">
			<signing key="file:///usr/share/distribution-gpg-keys/epel/RPM-GPG-KEY-EPEL-10"/>
		</source>
	</repository>
	<repository type="rpm-md" alias="elrepo" sourcetype="mirrorlist">
		<source path="http://mirrors.elrepo.org/mirrors-elrepo.el10">
			<signing key="file:///etc/pki/rpm-gpg/RPM-GPG-KEY-v2-elrepo.org"/>
		</source>
	</repository>
	<repository type="rpm-md" alias="elrepo-extras" sourcetype="baseurl">
		<source path="https://elrepo.org/linux/extras/el10/$basearch">
			<signing key="file:///etc/pki/rpm-gpg/RPM-GPG-KEY-v2-elrepo.org"/>
		</source>
	</repository>
	<repository type="rpm-md" alias="elrepo-kernel" sourcetype="baseurl">
		<source path="https://elrepo.org/linux/kernel/el10/$basearch">
			<signing key="file:///etc/pki/rpm-gpg/RPM-GPG-KEY-v2-elrepo.org"/>
		</source>
	</repository>
	<profiles>
		<profile name="Pumice" description="CentOS Stream 10"/>
	</profiles>
	<packages type="image" profiles="Pumice">
		<!-- groups to install, see "dnf group list" and "https://dnf.readthedocs.io/en/latest/command_ref.html" for more info -->
		<namedCollection name="anaconda-tools"/>
		<namedCollection name="core"/>
		<namedCollection name="fonts"/>
		<namedCollection name="hardware-support"/>
		<namedCollection name="multimedia"/>
		<namedCollection name="networkmanager-submodules"/>
		<namedCollection name="standard"/>
		<!-- packages to ignore/make sure are not installed -->
		<ignore name="PackageKit-command-not-found"/>
		<ignore name="device-mapper-multipath"/>
		<ignore name="fcoe-utils"/>
		<ignore name="gfs2-utils"/>
		<ignore name="gnome-initial-setup"/>
		<ignore name="gnome-tour"/>
		<ignore name="kernel-*debug*"/>
		<ignore name="kernel-dump"/>
		<ignore name="kernel-srpm-macros"/>
		<ignore name="malcontent-control"/>
		<ignore name="python3-boto3"/>
		<ignore name="qemu-user-static"/>
		<ignore name="reiserfs-utils"/>
		<!-- packages, be careful when removing as some packages are required by the installer -->
		<package name="amd-ucode-firmware"/>
		<package name="anaconda"/>
		<package name="anaconda-install-env-deps"/>
		<package name="anaconda-liveinst"/>
		<package name="bat"/>
		<package name="bind-utils"/>
		<package name="btop"/>
		<package name="cockpit"/>
		<package name="cockpit-files"/>
		<package name="cockpit-packagekit"/>
		<package name="cockpit-storaged"/>
		<package name="dbus-daemon"/>
		<package name="dconf-editor"/>
		<package name="ddcutil"/>
		<package name="dialog"/>
		<package name="dracut-live"/>
		<package name="elrepo-release"/>
		<package name="epel-release"/>
		<package name="fastfetch"/>
		<package name="flatpak"/>
		<package name="flatseal"/>
		<package name="fstrm"/>
		<package name="git"/>
		<package name="git-lfs"/>
		<package name="gjs"/>
		<package name="glibc-all-langpacks"/>
		<package name="gnome-bluetooth"/>
		<package name="gnome-browser-connector"/>
		<package name="gnome-clocks"/>
		<package name="gnome-control-center"/>
		<package name="gnome-disk-utility"/>
		<package name="gnome-shell-extension-blur-my-shell"/>
		<package name="gnome-shell-extension-caffeine"/>
		<package name="gnome-shell-extension-dash-to-dock"/>
		<package name="gnome-shell-extension-just-perfection"/>
		<package name="gnome-extensions-app"/>
		<package name="gnome-keyring"/>
		<package name="gnome-session-wayland-session"/>
		<package name="gnome-shell-extension-appindicator"/>
		<package name="gnome-software"/>
		<package name="gnome-text-editor"/>
		<package name="gnome-tweaks"/>
		<package name="firefox"/>
		<package name="grub2-efi-x64"/>
		<package name="grub2-efi-x64-cdboot"/>
		<package name="grub2-efi-x64-modules"/>
		<package name="grub2-pc"/>
		<package name="grub2-pc-modules"/>
		<package name="gtk4"/>
		<package name="htop"/>
		<package name="ipcalc"/>
		<package name="iperf3"/>
		<package name="iptstate"/>
		<package name="isomd5sum"/>
		<package name="kernel"/>
		<package name="kernel-core"/>
		<package name="kernel-modules"/>
		<package name="kernel-modules-extra"/>
		<package name="less"/>
		<package name="libadwaita"/>
		<package name="libva-intel-hybrid-driver"/>
		<package name="livesys-scripts"/>
		<package name="lm_sensors"/>
		<package name="man-db"/>
		<package name="mc"/>
		<package name="microcode_ctl"/>
		<package name="loupe"/>
		<package name="mpv"/>
		<package name="nano"/>
		<package name="nautilus"/>
		<package name="ncdu"/>
		<package name="NetworkManager-tui"/>
		<package name="openssh-server"/>
		<package name="papers"/>
		<package name="PackageKit"/>
		<package name="pcp"/>
		<package name="perl-Image-ExifTool"/>
		<package name="pigz"/>
		<package name="plymouth"/>
		<package name="plymouth-theme-spinner"/>
		<package name="ptyxis"/>
		<package name="python3-pcp"/>
		<package name="ripgrep"/>
		<package name="rootfiles"/>
		<package name="screen"/>
		<package name="seahorse"/>
		<package name="setroubleshoot-server"/>
		<package name="shim-signed-x64"/>
		<package name="sqlite"/>
		<package name="stress-ng"/>
		<package name="systemd-oomd-defaults"/>
		<package name="systemd-resolved"/>
		<package name="telnet"/>
		<package name="thermald"/>
		<package name="tio"/>
		<package name="traceroute"/>
		<package name="tuned"/>
		<package name="tuned-ppd"/>
		<package name="whois"/>
		<package name="xdg-utils"/>
		<package name="yum-utils"/>
		<package name="zram-generator"/>
		<package name="zsh"/>
	</packages>
	<!-- bootstrap packahes -->
	<packages type="bootstrap">
		<package name="basesystem"/>
		<package name="filesystem"/>
	</packages>
	<preferences profiles="Pumice">
		<type image="iso" publisher="Pumice" volid="Pumice" primary="true" flags="dmsquash" filesystem="erofs" fscreateoptions="--workers=NPROC_PLACEHOLDER -Efragments -C 1048576" erofscompression="lzma,level=9" mediacheck="true" firmware="uefi" efifatimagesize="30" kernelcmdline="quiet rhgb inst.kdump_addon=off systemd.show_status=auto biosdevname=0 net.ifnames=0 thunderbolt.host_reset=false inst.geoloc=0 inst.keymap=US" bundle_format="Pumice-CentOS-%v-%A">
			<bootloader name="grub2" grub_template="grub.template" console="console" timeout="10"/>
		</type>
	</preferences>
	<users profiles="Pumice">
		<!-- password will be erased by config.sh -->
		<user name="root" groups="root" password="linux" home="/root" pwdformat="plain" />
	</users>
</image>
